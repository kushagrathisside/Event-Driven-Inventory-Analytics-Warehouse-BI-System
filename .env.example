MW_ENV=local

# Optional network proxy settings.
# Use full URLs when needed, for example:
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1,postgres,kafka,zookeeper
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,postgres,kafka,zookeeper,localhost:5432,localhost:9092

MW_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
MW_KAFKA_INVENTORY_TOPIC=inventory_events
MW_KAFKA_PROCUREMENT_TOPIC=procurement_events
MW_KAFKA_SALES_TOPIC=sales_events

MW_MASTER_DB_HOST=localhost
MW_MASTER_DB_PORT=5432
MW_MASTER_DB_NAME=medwarehouse_master
MW_MASTER_DB_USER=postgres
MW_MASTER_DB_PASSWORD=postgres

MW_ANALYTICS_ADMIN_DB_HOST=localhost
MW_ANALYTICS_ADMIN_DB_PORT=5432
MW_ANALYTICS_ADMIN_DB_NAME=medwarehouse_analytics
MW_ANALYTICS_ADMIN_DB_USER=postgres
MW_ANALYTICS_ADMIN_DB_PASSWORD=postgres

MW_ANALYTICS_WRITER_DB_HOST=localhost
MW_ANALYTICS_WRITER_DB_PORT=5432
MW_ANALYTICS_WRITER_DB_NAME=medwarehouse_analytics
MW_ANALYTICS_WRITER_DB_USER=spark_writer
MW_ANALYTICS_WRITER_DB_PASSWORD=spark_writer_pwd

MW_ANALYTICS_READER_DB_HOST=localhost
MW_ANALYTICS_READER_DB_PORT=5432
MW_ANALYTICS_READER_DB_NAME=medwarehouse_analytics
MW_ANALYTICS_READER_DB_USER=analytics_reader
MW_ANALYTICS_READER_DB_PASSWORD=analytics_reader_pwd

MW_ANALYTICS_FDW_READER_USER=fdw_reader
MW_ANALYTICS_FDW_READER_PASSWORD=fdw_reader_pwd
MW_FDW_REMOTE_USER=postgres
MW_FDW_REMOTE_PASSWORD=postgres

MW_SPARK_MASTER=local[*]
MW_SPARK_LOG_LEVEL=WARN

MW_PRODUCER_INTERVAL_SECONDS=1
MW_PRODUCER_MAX_EVENTS=10
MW_PRODUCER_DRY_RUN=false
MW_SAMPLE_SEED=medical-warehouse-local
MW_SAMPLE_START_TIME=2026-01-01T08:00:00+00:00
MW_SAMPLE_PRODUCT_ID=P-LOCAL-CALPOL-500
MW_SAMPLE_WAREHOUSE_ID=W-LOCAL-RECEIVING-01
MW_SAMPLE_SUPPLIER_ID=SUP-LOCAL-HIMALAYAN
MW_SAMPLE_BATCH_NUMBER=BATCH-LOCAL-001
MW_SAMPLE_EXPIRY_DATE=2027-12-31
MW_SAMPLE_CURRENCY=INR

AIRFLOW_UID=50000

# API key authentication
# Set a random secret string (e.g. openssl rand -hex 32).
# Leave blank to disable auth (acceptable for local dev only).
MW_WEBAPP_API_KEY=
MW_PLATFORM_API_KEY=

# Flask session secret for platform control panel flash messages.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Falls back to a random per-process token in dev (flash messages lost on restart).
MW_PLATFORM_SECRET_KEY=

# Platform service coordinates used by the operator webapp to trigger Gold pipelines.
# These must match the host/port where `python -m medwarehouse platform serve` is running.
MW_PLATFORM_HOST=127.0.0.1
MW_PLATFORM_PORT=8787

# Airflow admin credentials for the Docker Compose stack.
# Only used by the airflow-init container on first startup.
AIRFLOW_ADMIN_PASSWORD=admin

# Operator webapp (port 8080) — supplier email notifications
# Leave MW_SMTP_HOST blank to skip email and only log the dispatch.
# NOTE: Airflow webserver is mapped to host port 8090 to avoid conflict with this webapp.
MW_SMTP_HOST=
MW_SMTP_PORT=587
MW_SMTP_USER=
MW_SMTP_PASSWORD=
MW_SMTP_FROM=noreply@medwarehouse.local
# Override all supplier emails to a single address during testing:
MW_SUPPLIER_EMAIL_OVERRIDE=
